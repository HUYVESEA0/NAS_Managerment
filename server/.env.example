# Copy file nay thanh .env va dien gia tri thuc
# cp .env.example .env

# ========================
# Server
# ========================
NODE_ENV=production
PORT=3001

# ========================
# Database (SQLite)
# Prisma resolves path relative to schema.prisma (server/prisma/)
# "file:./app.db" => server/prisma/app.db
# ========================
DATABASE_URL="file:./app.db"

# ========================
# JWT Authentication
# QUAN TRONG: Thay bang chuoi ngau nhien dai truoc khi deploy!
# Tao bang: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ========================
JWT_SECRET=your_super_secret_key_change_this
JWT_EXPIRES_IN=7d

# ========================
# Security
# CORS: Danh sach cac origin duoc phep truy cap (production)
# Vi du: ALLOWED_ORIGINS=http://192.168.1.100:3001,https://yourdomain.com
# De trong = cho phep tat ca (chi dung cho dev/internal)
# ========================
ALLOWED_ORIGINS=

# Bat buoc scope may theo permission MACHINE:<id> (true/false)
ENFORCE_MACHINE_SCOPES=false

# Khoa tai khoan tam thoi sau so lan login sai
MAX_FAILED_LOGINS=5
LOGIN_LOCKOUT_MINUTES=15

# Encrypt SSH credentials at rest (32 bytes hex khuyen nghi)
# Tao bang: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SSH_CREDENTIALS_KEY=

# Optional: sign server->agent WS requests
# Tao bang: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WS_AGENT_SHARED_SECRET=
