// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         Int         @id @default(autoincrement())
  username   String      @unique
  password   String
  roleId     Int
  role       Role        @relation(fields: [roleId], references: [id])
  savedPaths   SavedPath[]
  activityLogs ActivityLog[]
  createdAt    DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  permissions String   // JSON string of permissions e.g., ["READ_FLOOR", "WRITE_FILE"]
  users       User[]
}

model Floor {
  id          Int      @id @default(autoincrement())
  name        String
  level       Int      @unique
  description String?
  rooms       Room[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Room {
  id          Int       @id @default(autoincrement())
  name        String
  floorId     Int
  floor       Floor     @relation(fields: [floorId], references: [id])
  machines    Machine[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Machine {
  id          Int          @id @default(autoincrement())
  name        String
  ipAddress   String?
  username    String?      // SSH Username
  password    String?      // SSH Password (Encrypted in real app)
  port        Int          @default(22)
  status      String       @default("offline") // online, offline, maintenance
  sharedPaths String?      // JSON array of allowed paths e.g. ["C:/Data","D:/Backup"]
  roomId      Int
  room        Room         @relation(fields: [roomId], references: [id])
  mountPoints MountPoint[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// Representing a shared folder or simulated volume on a machine
model MountPoint {
  id        Int      @id @default(autoincrement())
  name      String
  path      String   // Path to directory (simulated or real)
  machineId Int
  machine   Machine  @relation(fields: [machineId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Saved/bookmarked paths per user — CRUD đường dẫn nhanh
model SavedPath {
  id        Int      @id @default(autoincrement())
  label     String   // Display name, e.g. "Backup Folder"
  path      String   // Full file path, e.g. "D:/Backup/weekly"
  machineId Int?     // Optional: null = global, specific = bound to machine
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  color     String?  // Optional hex color for UI tagging
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// System activity log — ghi lại mọi hành động quan trọng
model ActivityLog {
  id        Int      @id @default(autoincrement())
  level     String   @default("info") // info, warn, error
  category  String   // auth, file, agent, hierarchy, system, user
  action    String   // login, upload, delete, connect, disconnect, etc.
  message   String
  meta      String?  // JSON string for extra context
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  machineId Int?     // Optional: which machine this activity is about
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([category])
  @@index([createdAt])
  @@index([machineId])
  @@index([userId])
}
